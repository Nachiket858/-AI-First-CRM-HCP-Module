# Groq API Key
GROQ_API_KEY=GROQ_API_KEY

# Groq Model (gemma2-9b-it or llama-3.3-70b-versatile)
GROQ_MODEL=gemma2-9b-it

# Database connection URL (defaults to SQLite, change for MySQL or PostgreSQL)
# DATABASE_URL=mysql+pymysql://user:password@localhost/hcp_crm
# DATABASE_URL=postgresql://user:password@localhost/hcp_crm
DATABASE_URL=sqlite:///./hcp_crm.db
